"amixer set Master toggle"
  XF86AudioMute

"amixer set Master 1%+"
  XF86AudioRaiseVolume

"amixer set Master 1%-"
  XF86AudioLowerVolume

"playerctl previous"
    XF86AudioPrev
    reload_status_bar

"playerctl next"
    XF86AudioNext
    reload_status_bar

"playerctl play-pause"
    XF86AudioPlay

